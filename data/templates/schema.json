{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Template Pack Schema",
  "description": "Schema for Choyce Engine template packs",
  "type": "object",
  "properties": {
    "template_id": {
      "type": "string",
      "description": "Unique identifier for the template"
    },
    "name": {
      "type": "string",
      "description": "English name of the template"
    },
    "name_pl": {
      "type": "string",
      "description": "Polish name of the template"
    },
    "description_pl": {
      "type": "string",
      "description": "Polish description of the template"
    },
    "theme": {
      "type": "string",
      "description": "Theme category (business, adventure, etc.)"
    },
    "default_world": {
      "type": "object",
      "properties": {
        "name_pl": {
          "type": "string",
          "description": "Polish name for the default world"
        },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "description": "Node type (TERRAIN, OBJECT, etc.)"
              },
              "display_name_pl": {
                "type": "string",
                "description": "Polish display name"
              },
              "position": {
                "type": "array",
                "items": {
                  "type": "number"
                },
                "minItems": 3,
                "maxItems": 3,
                "description": "X, Y, Z position"
              }
            },
            "required": ["type", "display_name_pl", "position"]
          }
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "description": "Rule type (TIMER, SCORE, etc.)"
              },
              "display_name_pl": {
                "type": "string",
                "description": "Polish display name"
              },
              "compiled_logic": {
                "type": "string",
                "description": "Compiled rule logic"
              }
            },
            "required": ["type", "display_name_pl"]
          }
        }
      },
      "required": ["name_pl"]
    },
    "onboarding_hints_pl": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Polish onboarding hints"
    }
  },
  "required": ["template_id", "name_pl", "default_world"]
}